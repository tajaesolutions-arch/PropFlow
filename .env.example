# PropFlow environment template
# Copy this file to .env.local for local development. Never commit real .env files.

# -----------------------------------------------------------------------------
# Frontend-safe Vite variables (available in browser bundles)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_ENV=local
VITE_APP_URL=http://localhost:5173
# Set to true only after the private workspace-files bucket exists and storage policies are applied.
VITE_SUPABASE_STORAGE_CONFIGURED=false

# -----------------------------------------------------------------------------
# Server-only variables for Vercel API routes (DO NOT prefix with VITE_)
# Keep these in Vercel Project Settings or local server env only.
# Never expose service-role, Stripe, Resend, or Twilio secrets to frontend code.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Canonical deployed app origin for Vercel API CORS. VERCEL_URL is provided automatically by Vercel.
APP_URL=
# WARNING: only server endpoints that require trusted admin work may use this.
# Never place SUPABASE_SERVICE_ROLE_KEY in frontend code, VITE_* vars, logs, or responses.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe subscriptions and direct booking Checkout (server-only). Required for /api/create-stripe-checkout-session, /api/create-direct-booking-request payment mode, and /api/stripe-webhook.
# Missing values return a safe provider_not_configured response; never commit real keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Resend transactional email (server-only; external sends are not live until explicitly implemented)
RESEND_API_KEY=

# Twilio SMS/WhatsApp (server-only; external sends are not live until explicitly implemented)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_FROM=
